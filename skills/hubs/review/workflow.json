{
  "schema_version": 1,
  "kind": "domain_hub_workflow",
  "domain_id": 4,
  "domain": "Review",
  "hub": "review",
  "slash": "/review",
  "path": "skills/review",
  "package_dir": "hubs/review/",
  "role": "Domain router for verification modes \u2014 change review, security audit, architecture review, strategy.",
  "notes": "Ship closer still lands on sub-hub /code-review, not this hub. Open-ended review asks use F-R1.",
  "parent": {
    "hub": "butler",
    "slash": "/butler",
    "relationship": "routed_by",
    "html": "../butler/hub.html",
    "workflow_json": "../butler/workflow.json",
    "skill_path": "skills/butler"
  },
  "children": [
    {
      "link_type": "sub-hub",
      "skills": [
        "code-review",
        "security-auditor"
      ]
    },
    {
      "link_type": "on-ramp",
      "skills": [
        "codebase-review-strategy"
      ]
    },
    {
      "link_type": "soft",
      "skills": [
        "security-and-hardening",
        "software-architect"
      ],
      "note": "hardening shared with both sub-hubs; software-architect dual-primary under Architecture"
    },
    {
      "link_type": "cousin",
      "skills": [
        "verify-work",
        "ponytail-review"
      ],
      "note": "Mid-build verify and over-engineering review cousins"
    }
  ],
  "pipeline": [
    "orient",
    "F-R1 pick mode",
    "sub-hub or skill",
    "optional security-and-hardening remediation"
  ],
  "forks": [
    {
      "id": "F-R1",
      "question": "What kind of review?",
      "recommended": "Multi-axis change review if PR/ship/diff",
      "branches": [
        "code-review",
        "security-auditor",
        "software-architect",
        "codebase-review-strategy first",
        "Agent judgment"
      ]
    },
    {
      "id": "F6",
      "question": "(inside code-review) axes applicable?",
      "recommended": "Every applicable",
      "branches": [
        "Spec / Standards / Maintainability on or soft-skip",
        "Agent judgment"
      ]
    },
    {
      "id": "F-R2",
      "question": "(inside security-auditor) audit scope?",
      "recommended": "Full project unless path/PR named",
      "branches": [
        "full",
        "scoped module",
        "differential/PR",
        "Agent judgment"
      ]
    }
  ],
  "domain_hubs_routed": null,
  "artifacts": {
    "html": "./hub.html",
    "workflow_json": "./workflow.json",
    "flows_chart": "../flows-chart.html",
    "flows_ssot": "../../../skills/butler/references/flows.md",
    "hubs_index": "../index.html",
    "manifest": "../manifest.json"
  },
  "rules": [
    "butler_links_every_domain_hub",
    "each_domain_hub_has_package_dir",
    "each_domain_hub_has_hub_html",
    "each_domain_hub_has_workflow_json",
    "each_domain_hub_links_flows_chart",
    "one_hub_per_domain",
    "forks_ask_user"
  ]
}
