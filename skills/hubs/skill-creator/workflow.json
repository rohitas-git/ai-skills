{
  "schema_version": 1,
  "kind": "domain_hub_workflow",
  "domain_id": 11,
  "domain": "Author body",
  "hub": "skill-creator",
  "slash": "/skill-creator",
  "path": "skills/skill-creator",
  "package_dir": "hubs/skill-creator/",
  "role": "Craft skill bodies and evals.",
  "notes": "Body craft only; placement and indexes are skill-manager's job.",
  "parent": {
    "hub": "butler",
    "slash": "/butler",
    "relationship": "routed_by",
    "html": "../butler/hub.html",
    "workflow_json": "../butler/workflow.json",
    "skill_path": "skills/butler"
  },
  "children": [
    {
      "link_type": "wrapper",
      "skills": [
        "create-skill"
      ]
    },
    {
      "link_type": "craft",
      "skills": [
        "writing-great-skills"
      ]
    },
    {
      "link_type": "next",
      "skills": [
        "skill-manager"
      ],
      "note": "place/ingest"
    }
  ],
  "pipeline": [
    "author body",
    "optional place/ingest via skill-manager"
  ],
  "forks": [
    {
      "id": "F10",
      "question": "Ingest/place into catalog now?",
      "recommended": "yes when ready",
      "branches": [
        "stay crafting",
        "skill-manager place/ingest"
      ]
    }
  ],
  "domain_hubs_routed": null,
  "artifacts": {
    "html": "./hub.html",
    "workflow_json": "./workflow.json",
    "flows_chart": "../flows-chart.html",
    "flows_ssot": "../../../skills/butler/references/flows.md",
    "hubs_index": "../index.html",
    "manifest": "../manifest.json"
  },
  "rules": [
    "butler_links_every_domain_hub",
    "each_domain_hub_has_package_dir",
    "each_domain_hub_has_hub_html",
    "each_domain_hub_has_workflow_json",
    "each_domain_hub_links_flows_chart",
    "one_hub_per_domain",
    "forks_ask_user"
  ]
}
