{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/security-auditor-findings.schema.json",
  "title": "Security Auditor Findings",
  "description": "Schema for verified findings produced by the security-auditor skill",
  "type": "object",
  "required": ["audit_metadata", "findings"],
  "properties": {
    "audit_metadata": {
      "type": "object",
      "required": ["project", "timestamp", "scope", "phases_completed"],
      "properties": {
        "project": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "scope": { "type": "string", "description": "Full project or specific paths/modules" },
        "phases_completed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prior_findings_loaded": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "severity",
          "category",
          "location",
          "scenario",
          "impact",
          "confidence",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable unique identifier, e.g. SEC-001 or LOGIC-003"
          },
          "title": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["Critical", "High", "Medium", "Low"]
          },
          "category": {
            "type": "string",
            "description": "Primary category",
            "enum": ["security", "logic", "ambiguity", "bug"]
          },
          "subcategory": {
            "type": "string",
            "description": "Optional finer classification, e.g. injection, race-condition, broken-access-control"
          },
          "owasp_mapping": {
            "type": "string",
            "description": "Optional OWASP Top 10:2025 reference, e.g. A01"
          },
          "location": {
            "type": "object",
            "required": ["paths"],
            "properties": {
              "paths": {
                "type": "array",
                "items": { "type": "string" },
                "description": "File paths, optionally with line ranges, e.g. src/auth.py:42-67"
              },
              "functions": {
                "type": "array",
                "items": { "type": "string" }
              },
              "components": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "scenario": {
            "type": "string",
            "description": "Concrete steps or conditions that trigger the issue"
          },
          "impact": {
            "type": "string",
            "description": "What an attacker or user can achieve, or what fails"
          },
          "evidence": {
            "type": "string",
            "description": "Key code references or reasoning supporting the finding"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "status": {
            "type": "string",
            "enum": ["confirmed", "rejected", "needs-more-info"]
          },
          "remediation_hint": {
            "type": "string",
            "description": "High-level direction for fixing, not a full patch"
          },
          "is_new": {
            "type": "boolean",
            "description": "True if this finding was not present in a prior findings.json"
          },
          "related_findings": {
            "type": "array",
            "items": { "type": "string" },
            "description": "IDs of related findings"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_confirmed": { "type": "integer" },
        "by_severity": {
          "type": "object",
          "properties": {
            "Critical": { "type": "integer" },
            "High": { "type": "integer" },
            "Medium": { "type": "integer" },
            "Low": { "type": "integer" }
          }
        },
        "by_category": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      }
    }
  }
}
