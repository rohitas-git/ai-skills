{
  "python": {
    "command": "pyright-langserver",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".py": "python",
      ".pyi": "python"
    }
  },
  "pylsp": {
    "command": "pylsp",
    "args": ["--vy"],
    "extensionToLanguage": {
      ".py": "python",
      ".pyi": "python"
    }
  }
}
