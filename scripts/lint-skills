#!/usr/bin/env python3
"""Mirror skill-manager / skill-linter checklists for non-LLM / CI runs.

Exit 0 if no critical findings; exit 1 if any critical.
See ADR 0005 (hub packages) and ADR 0006 (skill-linter + hub membership).
"""
from __future__ import annotations

import json
import re
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
CATALOG = ROOT / "skills"
HUBS_DIR = CATALOG / "hubs"
FLOWS = CATALOG / "skills" / "0-butler" / "references" / "flows.md"
# Domain packages with live skills
LIVE_BUCKETS = ["skills"]  # flat live skill parent
BUCKETS = ["skills", "inbox", "archive"]
PROMOTED = {"skills"}  # root README points at skills/; promotion is "not archive/inbox"
HARD_DEP_SKILLS = {"1-to-spec", "1-to-tickets", "0-triage"}
FORBIDDEN_LIVE = {"using-agent-skills", "setup-matt-pocock-skills"}
# Live skills: {depth}-{kebab-slug} (CLAUDE.md / depth-prefix-names.md hard rule)
DEPTH_PREFIX = re.compile(r"^[0-9]+-[a-z0-9]+(-[a-z0-9]+)*$")
# workflow.json may list ops verbs that are not skills
NON_SKILL_TOKENS = {
    "create",
    "read",
    "update",
    "delete",
    "place",
    "new-hub",
    "ingest",
    "organize",
    "lint",
    "atomize",
    "Spec",
    "Standards",
    "Maintainability",
    "commit",
}
LEAN_SOFT_LINES = 120
LEAN_WARN_LINES = 180
SPRAWL_WARN_LINES = 250
SUBDOMAIN_WARN_LINES = 400
REF_COUNT_SUBDOMAIN = 5
MD_LINK = re.compile(r"\]\(([^)]+)\)")
PROCESS_HEADING = re.compile(
    r"(?im)^#{1,3}\s+(process|dispatch|steps|workflow|session start|build path)\b"
)


def skills_in_bucket(bucket: str) -> list[Path]:
    base = CATALOG / bucket
    if not base.is_dir():
        return []
    out = []
    for d in sorted(base.iterdir()):
        if d.is_symlink():
            continue  # dual-membership; primary counted in owning domain
        if d.is_dir() and (d / "SKILL.md").is_file():
            out.append(d)
    return out


def frontmatter(text: str) -> dict[str, str]:
    if not text.startswith("---"):
        return {}
    parts = text.split("---", 2)
    if len(parts) < 3:
        return {}
    meta = {}
    for line in parts[1].splitlines():
        if ":" in line and not line.startswith(" "):
            k, v = line.split(":", 1)
            meta[k.strip()] = v.strip().strip('"').strip("'")
    return meta


def collect_hub_members() -> set[str]:
    members: set[str] = set()
    if HUBS_DIR.is_dir():
        for wf in HUBS_DIR.glob("*/workflow.json"):
            try:
                data = json.loads(wf.read_text(encoding="utf-8"))
            except json.JSONDecodeError:
                continue
            hub = data.get("hub")
            if isinstance(hub, str) and hub:
                members.add(hub)
            for child in data.get("children") or []:
                skills = child.get("skills") or []
                for s in skills:
                    if isinstance(s, str) and s and s not in NON_SKILL_TOKENS:
                        members.add(s)
    if FLOWS.is_file():
        text = FLOWS.read_text(encoding="utf-8", errors="replace")
        for m in re.finditer(r"`([0-9]+-[a-z0-9]+(?:-[a-z0-9]+)*)`", text):
            name = m.group(1)
            if name not in NON_SKILL_TOKENS:
                members.add(name)
        for m in re.finditer(r"\*\*★ Hub\*\*\s*\|\s*`/([^`]+)`", text):
            members.add(m.group(1).strip())
    return members


def check_relative_links(skill_dir: Path, text: str, findings: list, rel: str) -> None:
    skip_exact = {"link", "url", "path", "href", "...", "file"}
    for m in MD_LINK.finditer(text):
        target = m.group(1).strip()
        if target.startswith(("http://", "https://", "mailto:", "file:", "#")):
            continue
        # strip anchors
        path_part = target.split("#", 1)[0].split("?", 1)[0]
        if not path_part or path_part.startswith("/"):
            continue
        # example / placeholder links in skill docs
        if path_part.lower() in skip_exact or "path/to" in path_part or path_part.startswith("<"):
            continue
        # only treat as filesystem paths when they look like relative files
        if not (
            path_part.startswith("./")
            or path_part.startswith("../")
            or path_part.startswith("references/")
            or path_part.startswith("scripts/")
            or path_part.endswith((".md", ".json", ".sh", ".py", ".txt", ".yaml", ".yml"))
        ):
            continue
        resolved = (skill_dir / path_part).resolve()
        try:
            resolved.relative_to(ROOT.resolve())
        except ValueError:
            continue
        if not resolved.exists():
            findings.append(("critical", "ref-exists", f"{rel}: broken link → {target}"))


def main() -> int:
    findings: list[tuple[str, str, str]] = []

    nested = []
    cfg = ROOT / "scripts" / "symlink-targets.json"
    if cfg.exists():
        nested = json.loads(cfg.read_text()).get("nestedSkillRoots") or []
    if any("agent-skills" in n for n in nested):
        findings.append(
            ("critical", "vendor", "nestedSkillRoots still includes agent-skills — dual-router risk")
        )

    using = list(CATALOG.rglob("using-agent-skills/SKILL.md"))
    for u in using:
        if "vendor" in u.parts:
            findings.append(
                ("info", "forbidden", f"using-agent-skills present under vendor only: {u.relative_to(ROOT)}")
            )
        else:
            findings.append(
                ("critical", "forbidden", f"using-agent-skills discoverable outside vendor: {u}")
            )

    if any((CATALOG / b / "setup-matt-pocock-skills").exists() for b in LIVE_BUCKETS):
        findings.append(("critical", "forbidden", "setup-matt-pocock-skills still present"))
    if not (CATALOG / "skills" / "0-setup-rohitas-skills" / "SKILL.md").exists():
        findings.append(("critical", "forbidden", "0-setup-rohitas-skills missing"))

    if any((CATALOG / b / "ask-matt").exists() for b in LIVE_BUCKETS):
        findings.append(
            ("critical", "forbidden", "ask-matt still under a live domain (should be archive)")
        )
    if not (CATALOG / "archive" / "ask-matt" / "SKILL.md").exists():
        findings.append(("warn", "tombstone", "ask-matt tombstone missing under archive/"))

    if not (CATALOG / "skills" / "0-butler" / "SKILL.md").exists():
        findings.append(("critical", "forbidden", "0-butler skill missing"))
    if not (CATALOG / "skills" / "1-skill-linter" / "SKILL.md").exists():
        findings.append(("critical", "forbidden", "1-skill-linter missing (ADR 0006)"))

    tdd_hits = [
        p
        for p in CATALOG.rglob("**/1-tdd/SKILL.md")
        if not any(x in p.parts for x in ("vendor", "archive", "hubs", "guidelines", "wikis"))
    ]
    tdd_hits += [
        p for p in CATALOG.rglob("**/test-driven-development/SKILL.md") if "vendor" not in p.parts
    ]
    if len([p for p in tdd_hits if p.parent.name == "1-tdd"]) != 1:
        findings.append(("warn", "tdd", f"unexpected tdd paths: {tdd_hits}"))
    if any(p.parent.name == "test-driven-development" and "vendor" not in p.parts for p in tdd_hits):
        findings.append(("critical", "tdd", "second TDD skill outside vendor"))

    # Hub package integrity (ADR 0005)
    if HUBS_DIR.is_dir():
        for wf in sorted(HUBS_DIR.glob("*/workflow.json")):
            hub_dir = wf.parent
            if not DEPTH_PREFIX.match(hub_dir.name):
                findings.append(
                    (
                        "critical",
                        "depth-hub",
                        f"hub package dir {hub_dir.name!r} must be depth-prefixed (0- for domain hubs, 1- for sub-hubs)",
                    )
                )
            try:
                data = json.loads(wf.read_text(encoding="utf-8"))
                hub = data.get("hub") or ""
                if hub and hub != hub_dir.name:
                    findings.append(
                        ("critical", "depth-hub", f"{hub_dir.name}: workflow hub={hub!r} != dir")
                    )
                if hub and not DEPTH_PREFIX.match(str(hub)):
                    findings.append(
                        ("critical", "depth-hub", f"{hub_dir.name}: workflow hub={hub!r} missing depth prefix")
                    )
            except json.JSONDecodeError:
                findings.append(("critical", "hub-workflow-json", f"invalid JSON: {wf}"))
            if not (hub_dir / "hub.html").is_file():
                findings.append(("critical", "hub-html", f"missing hub.html for {hub_dir.name}"))
        if not (HUBS_DIR / "manifest.json").is_file():
            findings.append(("warn", "hub-workflow-json", "hubs/manifest.json missing"))
    else:
        findings.append(("warn", "hub-dir", f"hub packages dir missing: {HUBS_DIR}"))

    # Depth-graph: name prefix must match primary hub-tree depth (dual membership adjusted)
    def expected_primary_depth(
        live: set[str],
    ) -> tuple[dict[str, int], dict[str, str], dict[str, list]]:
        """Return expected depth, primary parent, and all parents per skill."""
        wfs: dict[str, dict] = {}
        if HUBS_DIR.is_dir():
            for wf in HUBS_DIR.glob("*/workflow.json"):
                try:
                    data = json.loads(wf.read_text(encoding="utf-8"))
                except json.JSONDecodeError:
                    continue
                hub = data.get("hub")
                if isinstance(hub, str) and hub:
                    wfs[hub] = data
        domain = {h for h, d in wfs.items() if not d.get("parent_domain_hub")}
        sub = {h for h, d in wfs.items() if d.get("parent_domain_hub")}
        hdepth = {h: (1 if h in sub else 0) for h in wfs}
        prio = {
            "pipeline": 100,
            "hard": 90,
            "wrapper": 80,
            "sub-hub": 85,
            "leaf": 70,
            "satellite": 65,
            "on-ramp": 60,
            "pull-in": 55,
            "detour": 50,
            "persona": 45,
            "vocab": 45,
            "craft": 40,
            "next": 35,
            "cousin": 30,
            "routing": 25,
            "delegate": 20,
            "handoff": 15,
            "soft": 10,
            "axis": 5,
        }
        parents: dict[str, list] = {s: [] for s in live}
        for hub, data in wfs.items():
            for group in data.get("children") or []:
                lt = group.get("link_type") or "soft"
                if lt in ("tombstone", "ops", "ssot"):
                    continue
                primary_group = group.get("primary") is True
                for s in group.get("skills") or []:
                    if not isinstance(s, str) or s in NON_SKILL_TOKENS or s == hub:
                        continue
                    if s not in live:
                        continue
                    parents[s].append((hub, hdepth.get(hub, 0), lt, primary_group))
        expected: dict[str, int] = {}
        primary_of: dict[str, str] = {}
        for s in live:
            if s in domain:
                expected[s] = 0
                primary_of[s] = s
                continue
            if s in sub:
                expected[s] = 1
                primary_of[s] = s
                continue
            ps = parents.get(s) or []
            if not ps:
                continue
            explicit = [p for p in ps if p[3]]
            if explicit:
                pool = explicit
            else:
                best = max(prio.get(lt, 1) for _, _, lt, _ in ps)
                pool = [p for p in ps if prio.get(p[2], 1) == best]
                min_pd = min(p[1] for p in pool)
                pool = [p for p in pool if p[1] == min_pd]
            pool.sort(key=lambda x: x[0])
            parent, pd, lt, _ = pool[0]
            expected[s] = pd + 1
            primary_of[s] = f"{parent}({lt})"
        return expected, primary_of, parents

    live_names = {d.name for d in skills_in_bucket("skills")}
    exp_depth, primary_of, all_parents = expected_primary_depth(live_names)
    for name in sorted(live_names):
        m = re.match(r"^(\d+)-", name)
        if not m:
            continue  # depth-prefix check already flags
        actual = int(m.group(1))
        exp = exp_depth.get(name)
        if exp is None:
            findings.append(
                (
                    "critical",
                    "depth-graph",
                    f"skills/{name}: no hub parents and not a domain/sub-hub — cannot assign primary depth",
                )
            )
            continue
        if actual != exp:
            findings.append(
                (
                    "critical",
                    "depth-graph",
                    f"skills/{name}: name depth={actual} but primary hub-tree depth={exp} via {primary_of.get(name)}",
                )
            )
        if len(all_parents.get(name) or []) >= 2:
            findings.append(
                (
                    "info",
                    "depth-dual",
                    f"skills/{name}: dual membership; primary={primary_of.get(name)}; parents={[p[0] for p in all_parents[name]]}",
                )
            )

    hub_members = collect_hub_members()
    model_invoked: list[str] = []
    # Atomic root README: skill listing SSOT is wikis/index.md (not root README)
    wiki_index = (
        (CATALOG / "wikis" / "index.md").read_text(encoding="utf-8")
        if (CATALOG / "wikis" / "index.md").exists()
        else ""
    )
    orphans: list[str] = []

    for bucket in BUCKETS:
        readme = CATALOG / bucket / "README.md"
        readme_text = readme.read_text(encoding="utf-8") if readme.exists() else ""
        for d in skills_in_bucket(bucket):
            rel = f"{bucket}/{d.name}"
            text = (d / "SKILL.md").read_text(encoding="utf-8", errors="replace")
            lines = text.count("\n") + 1
            meta = frontmatter(text)
            name = meta.get("name", "")
            if name and name != d.name:
                findings.append(("critical", "name-dir", f"{rel}: name={name!r} != dir"))
            # Depth-prefix hard rule (live + inbox only)
            if bucket in ("skills", "inbox"):
                if not DEPTH_PREFIX.match(d.name):
                    findings.append(
                        (
                            "critical",
                            "depth-prefix",
                            f"{rel}: dir must be {{depth}}-{{kebab-slug}} (e.g. 0-butler, 1-to-tickets)",
                        )
                    )
                if name and not DEPTH_PREFIX.match(name):
                    findings.append(
                        (
                            "critical",
                            "depth-prefix",
                            f"{rel}: frontmatter name={name!r} missing depth prefix",
                        )
                    )
            fm = text.split("---", 2)[1] if text.startswith("---") else ""
            if "description:" not in fm:
                findings.append(("critical", "frontmatter", f"{rel}: missing description"))

            # Flat skills/: index lives in wikis/, not a per-skill bucket README listing
            if bucket == "skills":
                if d.name not in wiki_index and f"[[{d.name}]]" not in wiki_index:
                    findings.append(
                        ("warn", "wiki-index", f"{rel} not listed in wikis/index.md")
                    )
            elif bucket != "archive":
                if f"[{d.name}]" not in readme_text and d.name not in readme_text:
                    findings.append(("warn", "bucket-readme", f"{rel} not listed in bucket README"))

            if bucket in PROMOTED:
                if "disable-model-invocation: true" not in fm:
                    model_invoked.append(rel)

            if d.name in HARD_DEP_SKILLS and "0-setup-rohitas-skills" not in text and "setup-rohitas-skills" not in text:
                findings.append(
                    ("critical", "hard-dep", f"{d.name} missing /0-setup-rohitas-skills pointer")
                )

            if d.name in FORBIDDEN_LIVE and bucket in PROMOTED:
                findings.append(
                    ("critical", "forbidden", f"forbidden live skill in promoted bucket: {d.name}")
                )

            if "/Users/" in text and ("vault" in d.name.lower() or bucket == "personal"):
                findings.append(("warn", "vault-ssot", f"{rel} still contains /Users/ absolute path"))

            # Relative links from SKILL.md
            check_relative_links(d, text, findings, rel)

            # references orphans
            ref_dir = d / "references"
            if ref_dir.is_dir():
                linked = set()
                for m in MD_LINK.finditer(text):
                    tgt = m.group(1).split("#", 1)[0]
                    if "references/" in tgt or tgt.startswith("./references"):
                        linked.add(Path(tgt).name)
                ref_files = [p for p in ref_dir.rglob("*") if p.is_file() and p.suffix in {".md", ".json", ".txt"}]
                for rf in ref_files:
                    if rf.name not in linked and f"references/{rf.name}" not in text and rf.name not in text:
                        findings.append(
                            ("warn", "ref-orphan", f"{rel}: references/{rf.relative_to(ref_dir)} not linked from SKILL.md")
                        )
                if len(ref_files) > REF_COUNT_SUBDOMAIN and lines > SPRAWL_WARN_LINES:
                    findings.append(
                        (
                            "warn",
                            "subdomain-candidate",
                            f"{rel}: {lines} lines, {len(ref_files)} ref files — consider split or sub-domain hub",
                        )
                    )

            # Matt lean + sprawl (main SKILL.md must stay thin)
            has_refs_map = "references/" in text and (
                "progressive" in text.lower()
                or "load" in text.lower()
                or "| " in text
                or "](./references" in text
                or "](references/" in text
            )
            has_sibling_pointer = bool(
                re.search(r"\]\((?:\./)?[A-Za-z0-9_./-]+\.md\)", text)
            )
            disclosed = has_refs_map or (has_sibling_pointer and lines <= SPRAWL_WARN_LINES)
            if lines > SUBDOMAIN_WARN_LINES:
                findings.append(
                    (
                        "warn",
                        "subdomain-candidate",
                        f"{rel}: SKILL.md has {lines} lines — thin (Matt lean) then split or sub-domain hub",
                    )
                )
            elif lines > SPRAWL_WARN_LINES and not has_refs_map:
                findings.append(
                    (
                        "warn",
                        "sprawl",
                        f"{rel}: SKILL.md has {lines} lines without progressive disclosure — keep main file lean",
                    )
                )
            elif lines > LEAN_WARN_LINES and not disclosed:
                findings.append(
                    (
                        "warn",
                        "lean",
                        f"{rel}: SKILL.md has {lines} lines (Matt target ≤{LEAN_SOFT_LINES}; disclose refs if >{LEAN_WARN_LINES})",
                    )
                )
            elif lines > LEAN_SOFT_LINES:
                findings.append(
                    (
                        "info",
                        "lean-soft",
                        f"{rel}: SKILL.md has {lines} lines (soft lean target ≤{LEAN_SOFT_LINES})",
                    )
                )

            # Matt shape: process/dispatch/steps, tiny router, or intentional all-reference
            if lines > 100 and not PROCESS_HEADING.search(text):
                intentional_ref = bool(
                    re.search(
                        r"(?i)all reference|reference for |## (invocation|information hierarchy|pruning|failure modes)\b",
                        text,
                    )
                ) or (d / "GLOSSARY.md").is_file()
                if not intentional_ref:
                    findings.append(
                        (
                            "warn",
                            "matt-shape",
                            f"{rel}: no Process/Dispatch/Steps heading — Matt lean skills use ordered steps, tiny routers, or disclosed all-reference",
                        )
                    )

            # chain blurb heuristics
            chainish = bool(
                re.search(
                    r"(?i)(/tdd|/code-review|/implement|/to-spec|build path|related|next:|prev:|→)",
                    text,
                )
            )
            if bucket in LIVE_BUCKETS and d.name in hub_members and not chainish and lines > 30:
                # leaf tools (misc) often skip chain prose
                if True:  # flat skills: still emit chain-next info
                    findings.append(
                        (
                            "info",
                            "chain-next",
                            f"{rel}: no obvious chain/next blurb — pipeline skills should name next skill(s)",
                        )
                    )

            # hub membership (live only; personal residual = warn)
            if bucket in LIVE_BUCKETS:
                if d.name not in hub_members:
                    orphans.append(rel)
                    sev = "critical"
                    findings.append(
                        (
                            sev,
                            "hub-member",
                            f"{rel}: not listed under any domain hub workflow (flows.md / hubs/*/workflow.json)",
                        )
                    )

    if len(model_invoked) > 25:
        findings.append(
            (
                "warn",
                "model-budget",
                f"model-invoked promoted count {len(model_invoked)} > 25: {model_invoked[:12]}…",
            )
        )

    lock_path = CATALOG / "skills-lock.json"
    if lock_path.exists():
        lock = json.loads(lock_path.read_text())
        for sk, meta in lock.get("skills", {}).items():
            sp = meta.get("skillPath", "")
            candidates = [ROOT / sp, CATALOG / sp, CATALOG / sp.removeprefix("skills/")]
            if not any(c.is_file() for c in candidates):
                findings.append(("critical", "lock", f"lock path missing for {sk}: {sp}"))

    dep_readme = CATALOG / "archive" / "README.md"
    if dep_readme.exists():
        dep_text = dep_readme.read_text()
        for d in skills_in_bucket("archive"):
            if d.name not in dep_text:
                findings.append(("warn", "tombstone", f"archive/{d.name} not in deprecated README"))

    by: dict[str, list[str]] = {"critical": [], "warn": [], "info": []}
    for sev, code, msg in findings:
        by.setdefault(sev, []).append(f"- [{code}] {msg}")

    print("# Catalog lint")
    print(f"**Catalog root:** {CATALOG}")
    print(
        f"**Summary:** {len(by['critical'])} critical, {len(by['warn'])} warn, {len(by['info'])} info"
    )
    print(f"**Model-invoked promoted:** {len(model_invoked)}")
    print(f"**Hub members indexed:** {len(hub_members)}")
    print(f"**Hub-member orphans:** {len(orphans)}")
    if orphans:
        print(f"**Orphan sample:** {', '.join(orphans[:20])}{'…' if len(orphans) > 20 else ''}")
    print("**Gate:** FAIL" if by["critical"] else "**Gate:** PASS")
    for sev in ("critical", "warn", "info"):
        print(f"\n## {sev}")
        if by[sev]:
            print("\n".join(by[sev]))
        else:
            print("- (none)")

    return 1 if by["critical"] else 0


if __name__ == "__main__":
    sys.exit(main())
